{"status":"ok","message-type":"work-list","message-version":"1.0.0","message":{"facets":{},"total-results":945751,"items":[{"indexed":{"date-parts":[[2026,5,1]],"date-time":"2026-05-01T08:13:05Z","timestamp":1777623185518,"version":"3.51.4"},"publisher-location":"San Diego, California, USA","reference-count":0,"publisher":"Neural Information Processing Systems Foundation, Inc. (NeurIPS)","content-domain":{"domain":[],"crossmark-restriction":false},"published-print":{"date-parts":[[2022]]},"DOI":"10.52202\/068431-0037","type":"proceedings-article","created":{"date-parts":[[2026,3,2]],"date-time":"2026-03-02T13:17:52Z","timestamp":1772457472000},"page":"507-520","source":"Crossref","is-referenced-by-count":250,"title":["Why Do Tree-Based Models Still Outperform Deep Learning on Typical Tabular Data?"],"prefix":"10.52202","author":[{"given":"Leo","family":"Grinsztajn","sequence":"first","affiliation":[]},{"given":"Edouard","family":"Oyallon","sequence":"additional","affiliation":[]},{"given":"Gael","family":"Varoquaux","sequence":"additional","affiliation":[]}],"member":"29733","event":{"name":"Advances in Neural Information Processing Systems 35","theme":"36th Conference on Neural Information Processing Systems (NeurIPS 2022)","location":"New Orleans, Louisiana, USA","acronym":"NeurIPS 2022","number":"35","start":{"date-parts":[[2022,11,28]]},"end":{"date-parts":[[2022,12,9]]}},"container-title":["Advances in Neural Information Processing Systems 35"],"deposited":{"date-parts":[[2026,3,2]],"date-time":"2026-03-02T13:18:27Z","timestamp":1772457507000},"score":75.00108,"resource":{"primary":{"URL":"http:\/\/www.proceedings.com\/068431-0037.html"}},"issued":{"date-parts":[[2022]]},"references-count":0,"URL":"https:\/\/doi.org\/10.52202\/068431-0037","published":{"date-parts":[[2022]]}},{"institution":[{"id":[{"id":"https:\/\/ror.org\/03xjwb503","id-type":"ROR","asserted-by":"publisher"}],"name":"universit\u00e9 Paris-Saclay"}],"indexed":{"date-parts":[[2026,4,22]],"date-time":"2026-04-22T19:10:38Z","timestamp":1776885038213,"version":"3.51.2"},"reference-count":0,"publisher":"Agence Bibliographique de l'Enseignement Sup\u00e9rieur","content-domain":{"domain":[],"crossmark-restriction":false},"abstract":"<jats:title>R\u00e9concilier l'apprentissage profond avec les donn\u00e9es tabulaires<\/jats:title>\n                <jats:p xml:lang=\"fr\">L'apprentissage profond a connu un succ\u00e8s remarquable en vision par ordinateur et traitement du langage, mais ses performances restent encore d\u00e9cevantes sur les donn\u00e9es tabulaires, pourtant omnipr\u00e9sentes. Dans cette th\u00e8se, nous analysons d'abord les difficult\u00e9s que posent ces donn\u00e9es aux r\u00e9seaux de neurones. Pour \u00e9tayer cette analyse, nous d\u00e9veloppons de nouveaux standards d'\u00e9valuation, contribuant \u00e0 la fiabilit\u00e9 du domaine. Nous proposons ensuite diverses am\u00e9liorations, menant \u00e0 de puissants mod\u00e8les par d\u00e9faut. Nous \u00e9tudions \u00e9galement la repr\u00e9sentation des attributs textuels et num\u00e9riques: les mod\u00e8les de langage peuvent \u00eatre utiles pour repr\u00e9senter le texte, mais seulement dans certains r\u00e9gimes, et nous proposons un nouveau mod\u00e8le exploitant \u00e0 la fois le texte et les nombres. Enfin, nous montrons que de bonnes repr\u00e9sentations des nombres am\u00e9liorent les performances sur diverses t\u00e2ches, au-del\u00e0 m\u00eame des donn\u00e9es tabulaires.<\/jats:p>","DOI":"10.70675\/0c50c60dzd4edz4e4azb669zcbe0051b1dbe","type":"dissertation","created":{"date-parts":[[2026,4,8]],"date-time":"2026-04-08T23:27:17Z","timestamp":1775690837000},"approved":{"date-parts":[[2024,11,25]]},"source":"Crossref","is-referenced-by-count":1,"title":["Reconciling deep learning with tabular data"],"prefix":"10.70675","author":[{"sequence":"additional","affiliation":[]},{"ORCID":"https:\/\/orcid.org\/0000-0002-4006-8435","authenticated-orcid":false,"given":"L\u00e9o","family":"Grinsztajn","sequence":"first","affiliation":[{"id":[{"id":"https:\/\/ror.org\/03xjwb503","id-type":"ROR","asserted-by":"publisher"}],"name":"universit\u00e9 Paris-Saclay"}]}],"member":"51494","deposited":{"date-parts":[[2026,4,8]],"date-time":"2026-04-08T23:27:18Z","timestamp":1775690838000},"score":50.213593,"degree":["Doctorat \u00e8s Sciences du traitement du signal et des images","PhD"],"resource":{"primary":{"URL":"https:\/\/theses.fr\/2024UPASG065"}},"issued":{"date-parts":[[null]]},"references-count":0,"alternative-id":["2024UPASG065"],"URL":"https:\/\/doi.org\/10.70675\/0c50c60dzd4edz4e4azb669zcbe0051b1dbe"},{"indexed":{"date-parts":[[2026,4,23]],"date-time":"2026-04-23T06:48:56Z","timestamp":1776926936131,"version":"3.51.2"},"reference-count":0,"publisher":"ResearchHub Technologies, Inc.","content-domain":{"domain":[],"crossmark-restriction":false},"DOI":"10.55277\/researchhub.xajj3qck","type":"report","created":{"date-parts":[[2026,4,23]],"date-time":"2026-04-23T06:09:33Z","timestamp":1776924573000},"source":"Crossref","is-referenced-by-count":0,"title":["Why is deep learning struggling on tabular data?"],"prefix":"10.55277","author":[{"given":"Troof","family":"_","sequence":"first","affiliation":[]}],"member":"33940","published-online":{"date-parts":[[2026,4,23]]},"deposited":{"date-parts":[[2026,4,23]],"date-time":"2026-04-23T06:09:33Z","timestamp":1776924573000},"score":37.34059,"resource":{"primary":{"URL":"https:\/\/www.researchhub.com\/post\/225\/why-is-deep-learning-struggling-on-tabular-data"}},"issued":{"date-parts":[[2026,4,23]]},"references-count":0,"URL":"https:\/\/doi.org\/10.55277\/researchhub.xajj3qck","published":{"date-parts":[[2026,4,23]]}}],"items-per-page":3,"query":{"start-index":0,"search-terms":null}}}